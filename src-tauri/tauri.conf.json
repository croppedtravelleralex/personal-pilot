{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PersonaPilot",
  "version": "0.1.0",
  "identifier": "com.personapilot.localdesktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PersonaPilot",
        "width": 1480,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "devtools": false,
        "resizable": true,
        "fullscreen": false,
        "maximized": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
